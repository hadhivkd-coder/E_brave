# E-Brave API Configuration Examples
# Rename this file to .env.local and fill in the values below.

# Supabase Realtime Database Integrations
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Transactional WhatsApp Redirect Number
VITE_WA_NUMBER=919544547861

# Web App Public Script Redirections (Optional Google Sheets lead sync hook)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/xxxx/exec

# Analytics and Website Intelligence Tracking
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_CLARITY_PROJECT_ID=xxxxxxxxxx
VITE_META_PIXEL_ID=xxxxxxxxxxxxxxx

